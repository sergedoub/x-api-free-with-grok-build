#!/bin/sh
set -eu

runtime="$(mktemp -d /run/x-grok-reader/grok-login-XXXXXX)"
cleanup() {
  case "$runtime" in
    /run/x-grok-reader/grok-login-*) rm -rf -- "$runtime" ;;
  esac
}
trap cleanup EXIT HUP INT TERM

mkdir -p "$runtime/home"
install -m 600 /usr/local/lib/x-grok-reader/grok-home/requirements.toml \
  "$runtime/home/requirements.toml"
export HOME="$runtime"
export GROK_HOME="$runtime/home"
unset XAI_API_KEY
/usr/local/bin/grok login --device-auth
test -s "$runtime/home/auth.json"
install -m 600 "$runtime/home/auth.json" /var/lib/xreader-grok/auth.json
